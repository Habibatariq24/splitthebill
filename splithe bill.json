    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\n\n// Extract the actual text from the nested Responses API structure\nlet rawText;\ntry {\n  rawText = input.output[0].content[0].text;\n} catch (e) {\n  rawText = input.message ?? input.text ?? input.content; // fallback for other response formats\n}\n\nif (!rawText) {\n  return [{\n    json: {\n      error: \"unable to parse\",\n      reason: \"no text found in AI response\",\n      debug: JSON.stringify(input).slice(0, 300)\n    }\n  }];\n}\n\nlet data;\ntry {\n  const cleaned = rawText.replace(/```json|```/g, '').trim();\n  data = JSON.parse(cleaned);\n} catch (e) {\n  return [{\n    json: {\n      error: \"unable to parse\",\n      reason: \"invalid JSON from model\",\n      debug: rawText.slice(0, 300)\n    }\n  }];\n}\n\nif (data.error) {\n  return [{\n    json: {\n      error: data.error,\n      reason: data.reason || \"model reported an error\"\n    }\n  }];\n}\n\nif (\n  !data.payer ||\n  typeof data.amount !== 'number' ||\n  !Array.isArray(data.participants) ||\n  data.participants.length === 0\n) {\n  return [{\n    json: {\n      error: \"unable to parse\",\n      reason: \"missing payer, amount, or participants\",\n      debug: JSON.stringify(data)\n    }\n  }];\n}\n\nconst shareEach = Math.round((data.amount / data.participants.length) * 100) / 100;\n\nreturn [{\n  json: {\n    date: new Date().toISOString().split('T')[0],\n    payer: data.payer,\n    amount: data.amount,\n    participants: data.participants.join(\", \"),\n    shareEach: shareEach\n  }\n}];"
      },
