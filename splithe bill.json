    {
      "parameters": {
        "jsCode": "const rows = $input.all().map(item => item.json);\nconst balances = {}; // { \"debtor|||creditor\": amount }\n\nfor (const row of rows) {\n  const payer = (row.Payer || \"\").trim();\n  const amount = parseFloat(row.Amount);\n  const participants = (row.Participants || \"\")\n    .split(\",\")\n    .map(p => p.trim())\n    .filter(p => p.length > 0);\n\n  if (!payer || isNaN(amount) || participants.length === 0) continue;\n\n  const shareEach = amount / participants.length;\n\n  for (const person of participants) {\n    if (person === payer) continue;\n    const key = person + \"|||\" + payer;\n    balances[key] = (balances[key] || 0) + shareEach;\n  }\n}\n\nconst summary = Object.entries(balances).map(([key, amt]) => {\n  const [debtor, creditor] = key.split(\"|||\");\n  return { debtor, creditor, owes: Math.round(amt * 100) / 100 };\n});\n\nreturn [{ json: { summary } }];"
      },
      "type": "n8n-nodes-base.code",
